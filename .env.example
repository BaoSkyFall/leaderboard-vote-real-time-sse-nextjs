# --- Persistence (optional for local dev) ---
# When BOTH are set, the app uses Upstash Redis. When unset, it falls back to an
# in-memory store so `npm run dev` works with zero configuration.
# Create a free database at https://console.upstash.com/ (Redis) and copy the
# REST URL + REST token from the database "REST API" section.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Session signing ---
# HMAC secret used to sign the httpOnly session cookie. A dev fallback is used
# if unset, but ALWAYS set a strong random value in production (e.g.
# `openssl rand -hex 32`).
SESSION_SECRET=
